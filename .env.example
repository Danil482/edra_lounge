# Copy to .env and adjust

# LLM provider:
#   local    → Ollama on localhost (offline-capable booth default)
#   remote   → Anthropic Messages API
#   openai   → OpenAI Chat Completions API
LLM_MODE=local

# Local (Ollama) config
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct

# Remote (Anthropic) — dev/test only, never on booth machine
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI — dev/test only, never on booth machine.
# Key MUST be on a single line, no quotes, no parens, no concatenation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# EDRA thresholds
N_MIN=5
THETA_INDUCE=0.6
THETA_REVISE=0.5
RECLUSTER_EVERY=3
CS_WINDOW=5

# Demo
RNG_SEED=42
TICK_SECONDS=20
DB_PATH=edra_lounge.db

# Profile source mode
# LIVE_MODE=true   → LinkedIn-RapidAPI source (booth default; expects RAPIDAPI_KEY)
# LIVE_MODE=false  → synthetic auto-play (dev/test mode, deterministic from seed)
LIVE_MODE=true

# RAPIDAPI_KEY:
#   "mock"   → bypass HTTP, return hand-crafted author profile (booth-without-subscription)
#   <key>    → real fetches against fresh-linkedin-profile-data.p.rapidapi.com
RAPIDAPI_KEY=mock

RESEND_API_KEY=mock

LEMLIST_API_KEY=<from app.lemlist.com → Settings → Integrations → API>
LEMLIST_CAMPAIGN_ID=<from your campaign URL>
